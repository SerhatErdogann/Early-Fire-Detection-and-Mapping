<?xml version="1.0" encoding="UTF-8"?>
<sld:StyledLayerDescriptor xmlns="http://www.opengis.net/sld" xmlns:sld="http://www.opengis.net/sld" xmlns:ogc="http://www.opengis.net/ogc" xmlns:gml="http://www.opengis.net/gml" version="1.0.0">
    <sld:NamedLayer>
        <sld:Name>fire_heatmap</sld:Name>
        <sld:UserStyle>
            <sld:Name>fire_heatmap</sld:Name>
            <sld:FeatureTypeStyle>
                <sld:Transformation>
                    <ogc:Function name="gs:Heatmap">
                        <ogc:Function name="parameter">
                            <ogc:Literal>data</ogc:Literal>
                        </ogc:Function>
                        <ogc:Function name="parameter">
                            <ogc:Literal>weightAttr</ogc:Literal>
                            <ogc:Literal>last_probability</ogc:Literal>
                        </ogc:Function>
                        <ogc:Function name="parameter">
                            <ogc:Literal>radiusPixels</ogc:Literal>
                            <ogc:Literal>150</ogc:Literal>
                        </ogc:Function>
                    </ogc:Function>
                </sld:Transformation>
                <sld:Rule>
                    <sld:RasterSymbolizer>
                        <sld:Opacity>0.7</sld:Opacity>
                        <sld:ColorMap type="ramp">
                            <sld:ColorMapEntry color="#00000000" quantity="0" opacity="0"/>
                            <sld:ColorMapEntry color="#0000FF" quantity="0.2" opacity="0.4"/>
                            <sld:ColorMapEntry color="#00FFFF" quantity="0.4" opacity="0.5"/>
                            <sld:ColorMapEntry color="#00FF00" quantity="0.6" opacity="0.6"/>
                            <sld:ColorMapEntry color="#FFFF00" quantity="0.8" opacity="0.7"/>
                            <sld:ColorMapEntry color="#FF0000" quantity="1.0" opacity="0.8"/>
                        </sld:ColorMap>
                    </sld:RasterSymbolizer>
                </sld:Rule>
            </sld:FeatureTypeStyle>
        </sld:UserStyle>
    </sld:NamedLayer>
</sld:StyledLayerDescriptor>
